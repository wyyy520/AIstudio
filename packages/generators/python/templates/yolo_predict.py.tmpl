"""YOLO inference script - generated from workflow."""

import os
import logging
from pathlib import Path
from typing import Optional

logger = logging.getLogger(__name__)


class YOLOPredictor:
    """YOLO model inference generated from workflow."""

    def __init__(self, config: Optional[dict] = None):
        self.config = config or {}
        self.model_path = self.config.get("model_path", "models/train/weights/best.pt")
        self.source = self.config.get("source", None)
        self.conf = self.config.get("conf", 0.25)
        self.iou = self.config.get("iou", 0.45)
        self.imgsz = self.config.get("imgsz", 640)
        self.device = self.config.get("device", "cpu")
        self.project = self.config.get("project", "outputs")
        self.name = self.config.get("name", "predict")
        logger.info(
            "YOLOPredictor initialized: model=%s, source=%s",
            self.model_path, self.source,
        )

    def execute(self, **inputs) -> dict:
        """
        Execute YOLO inference.

        Args:
            **inputs: Input data (expected "model_path" key).

        Returns:
            Inference results.
        """
        logger.info("Starting YOLO inference...")

        try:
            from ultralytics import YOLO
        except ImportError:
            logger.error(
                "ultralytics is not installed. Run: pip install ultralytics"
            )
            raise

        model_path = inputs.get("model_path", self.model_path)
        source = inputs.get("source", self.source)

        if not os.path.isfile(model_path):
            logger.warning("Model not found: %s", model_path)
            return {"error": f"Model not found: {model_path}"}

        model = YOLO(model_path)

        results = model.predict(
            source=source,
            conf=self.conf,
            iou=self.iou,
            imgsz=self.imgsz,
            device=self.device,
            project=self.project,
            name=self.name,
            save=True,
            exist_ok=True,
        )

        logger.info("Inference complete. Results saved to: %s/%s", self.project, self.name)
        return {"results": results}
