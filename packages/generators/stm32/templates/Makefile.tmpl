# Directories
BUILD_DIR := build
SRC_DIR := Core/Src
INC_DIR := Core/Inc

# Sources
C_SOURCES := \
$(SRC_DIR)/main.c \
$(SRC_DIR)/stm32_it.c \
$(SRC_DIR)/aistudio_nodes.c

# Includes
C_INCLUDES := \
-I$(INC_DIR)

# MCU settings
MCU := -mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard
FPU := -D__FPU_USED=1
DEFS := -DUSE_HAL_DRIVER -DSTM32F407xx

# Optimization
OPT := -Og

# Compiler flags
CFLAGS := $(MCU) $(DEFS) $(C_INCLUDES) $(OPT) -Wall -Werror -std=c11

# Linker flags
LDFLAGS := $(MCU) -T$(LDSCRIPT) -Wl,-Map=$(BUILD_DIR)/$(TARGET).map
LIBS := -lc -lm -lnosys

# Build
OBJECTS := $(addprefix $(BUILD_DIR)/,$(notdir $(C_SOURCES:.c=.o)))
vpath %.c $(sort $(dir $(C_SOURCES)))

$(BUILD_DIR)/%.o: %.c Makefile | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/$(@F:.o=.lst) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) Makefile
	$(LD) $(OBJECTS) $(LDFLAGS) $(LIBS) -o $@
	$(OBJCOPY) -O ihex $@ $(BUILD_DIR)/$(TARGET).hex
	$(OBJCOPY) -O binary $@ $(BUILD_DIR)/$(TARGET).bin
	$(SIZE) $@

$(BUILD_DIR):
	mkdir -p $@

all: $(BUILD_DIR)/$(TARGET).elf

flash: all
	st-flash write $(BUILD_DIR)/$(TARGET).bin 0x8000000

clean:
	rm -rf $(BUILD_DIR)

.PHONY: all flash clean
