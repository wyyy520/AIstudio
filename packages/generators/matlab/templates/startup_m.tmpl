%% {{.ProjectName}}
%  Generated by AIStudio MATLAB Generator
%  Workflow: {{.WorkflowName}} ({{.WorkflowID}})
%  Target: {{.Target}}

function startup()
    % STARTUP Initializes the MATLAB project environment.
    %   Adds source directories to MATLAB path and sets up
    %   workspace for the AIStudio generated workflow.
    
    fprintf('Initializing project: %s\n', '{{.ProjectName}}');
    
    % Get the project root directory
    projectRoot = fileparts(mfilename('fullpath'));
    
    % Add scripts directory to path
    scriptsDir = fullfile(projectRoot, 'scripts');
    if exist(scriptsDir, 'dir')
        addpath(scriptsDir);
        fprintf('Added to path: %s\n', scriptsDir);
    end
    
    % Create results directory if it doesn't exist
    resultsDir = fullfile(projectRoot, 'results');
    if ~exist(resultsDir, 'dir')
        mkdir(resultsDir);
        fprintf('Created results directory: %s\n', resultsDir);
    end
    
    % Set up global configuration
    setappdata(0, 'ProjectRoot', projectRoot);
    setappdata(0, 'ProjectName', '{{.ProjectName}}');
    setappdata(0, 'ResultsDir', resultsDir);
    
    fprintf('Project initialization complete.\n');
end
