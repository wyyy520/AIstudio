! ANSYS Mechanical APDL Input File
! Project: {{.ProjectName}}
! Generated by AIStudio - {{.Version}}
! Purpose: Mechanical finite element analysis model definition

/FILNAME,{{.ProjectName}},1

/PREP7                          ! Enter preprocessor

! ========================================
! Element Type Definition
! ========================================
ET,1,SOLID185                    ! 8-node structural solid
ET,2,SHELL181                    ! 4-node structural shell
ET,3,BEAM188                     ! 2-node beam element

! ========================================
! Material Properties
! ========================================
MP,EX,1,{{or $config.youngs_modulus "2.0e5"}}         ! Young's Modulus [MPa]
MP,NUXY,1,{{or $config.poisson_ratio "0.3"}}          ! Poisson's Ratio
MP,DENS,1,{{or $config.density "7.85e-9"}}            ! Density [ton/mm³]
MP,ALPX,1,{{or $config.thermal_expansion "1.2e-5"}}   ! Thermal Expansion [1/°C]

! ========================================
! Geometry Import
! ========================================
! Import geometry from CAD file (if provided)
{{if $config.geometry_file}}
/INPUT,'{{$config.geometry_file}}','iges','.',0
{{else}}
! Manual geometry definition - replace with actual geometry
BLOCK,0,{{or $config.length "100"}},0,{{or $config.width "50"}},0,{{or $config.height "20"}}
{{end}}

! ========================================
! Meshing Controls
! ========================================
ESIZE,{{or $config.element_size "5"}}   ! Global element size
MSHAPE,{{or $config.mesh_shape "1"}},3D ! 0=quad, 1=tri (tet)
MSHKEY,{{or $config.mesh_type "0"}}     ! 0=free mesh, 1=mapped mesh
VMESH,ALL                                ! Mesh all volumes

FINISH

! ========================================
! Solution Setup
! ========================================
/SOLU
ANTYPE,STATIC                  ! Static analysis type
NLGEOM,ON                      ! Large deformation effects

! Boundary Conditions
{{if $config.fixed_surfaces}}
! Fixed support at specified surfaces
DA,{{$config.fixed_surfaces}},ALL,0
{{end}}

{{if $config.force}}
! Apply force load
F,{{$config.force_node}},{{$config.force_direction}},{{$config.force}}
{{end}}

{{if $config.pressure}}
! Apply pressure load
SFA,{{$config.pressure_surface}},1,PRES,{{$config.pressure}}
{{end}}

{{if $config.temperature}}
! Thermal load
BF,ALL,TEMP,{{$config.temperature}}
{{end}}

SOLVE
FINISH

! ========================================
! Post Processing
! ========================================
/POST1
SET,LAST                       ! Read last result set

PLNSOL,U,SUM,0,1.0             ! Plot total displacement
PLNSOL,S,EQV,0,1.0             ! Plot von Mises stress
PLNSOL,EPEL,EQV,0,1.0          ! Plot equivalent elastic strain

! Generate report data
*GET,max_disp,PLNSOL,0,MAX     ! Get maximum displacement
*GET,max_stress,PLNSOL,0,MAX   ! Get maximum stress

FINISH
