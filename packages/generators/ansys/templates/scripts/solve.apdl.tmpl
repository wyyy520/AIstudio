! Solver Configuration Script
! Project: {{.ProjectName}}
! Generated by AIStudio

/SOLU

! Analysis type
ANTYPE,STATIC
NLGEOM,ON

! Solver controls
EQSLV,SPARSE            ! Sparse direct solver
NSUBST,10,100,5         ! Substeps: initial, max, min
AUTOTS,ON               ! Automatic time stepping
LNSRCH,ON               ! Line search

! Convergence criteria
CNVTOL,F,,0.5,2,0.001   ! Force convergence tolerance
CNVTOL,U,,0.5,2,0.001   ! Displacement convergence tolerance

! Output controls
OUTRES,ALL,ALL          ! Output all results for all substeps
OUTPR,ALL,ALL           ! Print all results

! Damping (if needed)
! ALPHAD,5.0            ! Mass damping
! BETAD,0.0001          ! Stiffness damping

SOLVE
FINISH
