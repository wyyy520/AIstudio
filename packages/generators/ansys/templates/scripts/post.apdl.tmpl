! Post-Processing Script
! Project: {{.ProjectName}}
! Generated by AIStudio

/POST1

! Read last result set
SET,LAST

! ========================================
! Displacement Results
! ========================================
PLNSOL,U,SUM,0,1.0
*GET,max_disp,NODE,0,U,SUM
/output,results_displacement.txt
*VWRITE,max_disp
('Maximum Displacement: ',E15.6,' mm')
/output

! ========================================
! Stress Results
! ========================================
PLNSOL,S,EQV,0,1.0
NSORT,S,EQV,0,0,ALL,0
*GET,max_stress,SORT,0,MAX
/output,results_stress.txt
*VWRITE,max_stress
('Maximum von Mises Stress: ',E15.6,' MPa')
/output

! ========================================
! Strain Results
! ========================================
PLNSOL,EPEL,EQV,0,1.0
*GET,max_strain,NODE,0,EPEL,EQV
/output,results_strain.txt
*VWRITE,max_strain
('Maximum Elastic Strain: ',E15.6)
/output

! ========================================
! Reaction Forces
! ========================================
FSUM
/output,results_reaction.txt
*VWRITE
('Reaction Forces Summary:')
/output

! ========================================
! Export Results to CSV
! ========================================
*CFOPEN,results_summary,csv
*VWRITE
'Metric','Value','Unit'
*VWRITE
'Max Displacement',max_disp,'mm'
*VWRITE
'Max von Mises Stress',max_stress,'MPa'
*VWRITE
'Max Elastic Strain',max_strain,'-'
*CFCLOSE

! Generate deformation animation
/ANFILE,SAVE,deformation,AVI

FINISH
