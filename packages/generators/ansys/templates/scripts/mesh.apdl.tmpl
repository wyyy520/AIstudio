! Mesh Generation Script
! Project: {{.ProjectName}}
! Generated by AIStudio

/PREP7

! Element type assignment
ET,1,SOLID185
ET,2,SHELL181

! Material assignment
MAT,1

! Mesh sizing controls
ESIZE,5,0
SMRTSIZE,6              ! Smart sizing level (1=finest, 10=coarsest)

! Mesh quality controls
SHPP,ON                 ! Shape checking
SHPP,SUMM               ! Element shape summary

! Generate mesh
VMESH,ALL

! Mesh quality check
*GET,worst_aspect,ELEM,0,WORST,ASPECT
*GET,element_count,ELEM,0,COUNT
*GET,node_count,NODE,0,COUNT

! Output mesh statistics
/output,mesh_stats.txt
*VWRITE,element_count,node_count,worst_aspect
('Mesh Statistics:',/,
 '  Elements: ',F10.0,/,
 '  Nodes: ',F10.0,/,
 '  Worst Aspect Ratio: ',F5.2)
/output

FINISH
