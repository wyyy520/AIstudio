# {{.ProjectName}}
# Generated by AIStudio Docker Generator
# Workflow: {{.WorkflowName}} ({{.WorkflowID}})

version: "3.8"

services:
{{range .Services}}
  {{.Name}}:
    build:
      context: .
      dockerfile: Dockerfile
      target: production
    image: {{$.ProjectName}}-{{.Name}}:latest
    container_name: {{$.ProjectName}}-{{.Name}}
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      {{range .Volumes}}- {{.}}
      {{end}}
    networks:
      - aistudio-network
    labels:
      ai.aistudio.node.id: "{{.NodeID}}"
      ai.aistudio.node.type: "{{.NodeType}}"
{{end}}

networks:
  aistudio-network:
    driver: bridge
