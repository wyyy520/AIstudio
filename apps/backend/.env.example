# =============================================================================
# AIStudio - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# DO NOT commit .env to version control.
# =============================================================================

# -- Application ---------------------------------------------------------------
AISTUDIO_ENV=production

# -- Backend (Go) --------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8081

# -- Database ------------------------------------------------------------------
DATABASE_TYPE=postgres
DATABASE_URL=postgresql://aistudio:changeme@db:5432/aistudio

# -- JWT Authentication --------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRE=2h

# -- Python Engine -------------------------------------------------------------
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8082

# -- Redis (optional) ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- LLM Provider (for AI Agent) -----------------------------------------------
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# -- CORS (production) ---------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://aistudio.example.com

# -- Frontend (Vite build-time) ------------------------------------------------
VITE_APP_ENV=production
VITE_API_BASE_URL=
VITE_WS_URL=
VITE_ENGINE_URL=