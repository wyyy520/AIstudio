{
  "id": "yolo-detection",
  "name": "YOLO Target Detection",
  "description": "Complete YOLO-based target detection training pipeline with dataset loading, model training, and export",
  "category": "vision",
  "version": "2.0.0",
  "parameters": [
    {
      "name": "dataset_path",
      "type": "string",
      "label": "Dataset Path",
      "description": "Path to the YOLO-format dataset",
      "required": true
    },
    {
      "name": "model_name",
      "type": "enum",
      "label": "YOLO Model",
      "description": "YOLO model variant",
      "required": true,
      "default": "yolov8n.pt",
      "options": ["yolov8n.pt", "yolov8s.pt", "yolov8m.pt", "yolov8l.pt", "yolov8x.pt"]
    },
    {
      "name": "epochs",
      "type": "number",
      "label": "Training Epochs",
      "description": "Number of training epochs",
      "required": false,
      "default": 100,
      "min": 1,
      "max": 1000
    },
    {
      "name": "batch_size",
      "type": "number",
      "label": "Batch Size",
      "description": "Training batch size",
      "required": false,
      "default": 16,
      "min": 1,
      "max": 512
    },
    {
      "name": "device",
      "type": "enum",
      "label": "Device",
      "description": "Training device",
      "required": false,
      "default": "cuda",
      "options": ["cuda", "cpu", "mps"]
    },
    {
      "name": "export_format",
      "type": "enum",
      "label": "Export Format",
      "description": "Model export format",
      "required": false,
      "default": "onnx",
      "options": ["onnx", "torchscript", "tensorrt", "openvino"]
    }
  ],
  "workflow": {
    "schema_version": "2.0.0",
    "id": "yolo-detection-${dataset_path}",
    "name": "YOLO Detection Training",
    "description": "Train YOLO model on ${dataset_path} dataset",
    "version": 1,
    "target": "python",
    "variables": {
      "dataset_path": "${dataset_path}",
      "model_name": "${model_name}",
      "epochs": "${epochs}",
      "batch_size": "${batch_size}",
      "device": "${device}",
      "export_format": "${export_format}"
    },
    "nodes": [
      {
        "id": "node-data-loader",
        "type": "data_loader",
        "name": "Dataset Loader",
        "description": "Load YOLO-format dataset from ${dataset_path}",
        "position": { "x": 100, "y": 200 },
        "config": {
          "source": "${dataset_path}",
          "format": "yolo",
          "split_ratio": 0.8
        },
        "inputs": [],
        "outputs": [
          { "id": "out_dataset", "name": "dataset", "type": "dataset", "required": true }
        ]
      },
      {
        "id": "node-data-augment",
        "type": "data_augmentation",
        "name": "Data Augmentation",
        "description": "Apply data augmentation for better generalization",
        "position": { "x": 350, "y": 200 },
        "config": {
          "mosaic": 1.0,
          "mixup": 0.1,
          "hsv_h": 0.015,
          "hsv_s": 0.7,
          "hsv_v": 0.4,
          "degrees": 0.0,
          "translate": 0.1,
          "scale": 0.5,
          "shear": 0.0
        },
        "inputs": [
          { "id": "in_dataset", "name": "dataset", "type": "dataset", "required": true }
        ],
        "outputs": [
          { "id": "out_dataset", "name": "augmented_dataset", "type": "dataset" }
        ]
      },
      {
        "id": "node-trainer",
        "type": "model_trainer",
        "name": "YOLOv8 Trainer",
        "description": "Train YOLOv8 model with specified parameters",
        "position": { "x": 600, "y": 200 },
        "config": {
          "model": "${model_name}",
          "epochs": "${epochs}",
          "batch_size": "${batch_size}",
          "device": "${device}",
          "optimizer": "auto",
          "lr": 0.01,
          "patience": 50,
          "save_period": 10
        },
        "inputs": [
          { "id": "in_dataset", "name": "dataset", "type": "dataset", "required": true }
        ],
        "outputs": [
          { "id": "out_model", "name": "trained_model", "type": "model" }
        ]
      },
      {
        "id": "node-evaluator",
        "type": "model_evaluator",
        "name": "Model Evaluator",
        "description": "Evaluate trained model performance",
        "position": { "x": 850, "y": 150 },
        "config": {
          "metrics": ["mAP50", "mAP50-95", "precision", "recall"],
          "conf_threshold": 0.25,
          "iou_threshold": 0.45
        },
        "inputs": [
          { "id": "in_model", "name": "model", "type": "model", "required": true },
          { "id": "in_dataset", "name": "dataset", "type": "dataset", "required": true }
        ],
        "outputs": [
          { "id": "out_metrics", "name": "metrics", "type": "json" }
        ]
      },
      {
        "id": "node-exporter",
        "type": "model_exporter",
        "name": "Model Exporter",
        "description": "Export trained model to ${export_format} format",
        "position": { "x": 850, "y": 350 },
        "config": {
          "format": "${export_format}",
          "optimize": true,
          "half_precision": true,
          "dynamic_axes": true
        },
        "inputs": [
          { "id": "in_model", "name": "model", "type": "model", "required": true }
        ],
        "outputs": [
          { "id": "out_export", "name": "exported_model", "type": "file" }
        ]
      }
    ],
    "edges": [
      {
        "id": "edge-1",
        "source": { "node_id": "node-data-loader", "port_id": "out_dataset" },
        "target": { "node_id": "node-data-augment", "port_id": "in_dataset" }
      },
      {
        "id": "edge-2",
        "source": { "node_id": "node-data-augment", "port_id": "out_dataset" },
        "target": { "node_id": "node-trainer", "port_id": "in_dataset" }
      },
      {
        "id": "edge-3",
        "source": { "node_id": "node-trainer", "port_id": "out_model" },
        "target": { "node_id": "node-evaluator", "port_id": "in_model" }
      },
      {
        "id": "edge-4",
        "source": { "node_id": "node-data-loader", "port_id": "out_dataset" },
        "target": { "node_id": "node-evaluator", "port_id": "in_dataset" }
      },
      {
        "id": "edge-5",
        "source": { "node_id": "node-trainer", "port_id": "out_model" },
        "target": { "node_id": "node-exporter", "port_id": "in_model" }
      }
    ]
  }
}