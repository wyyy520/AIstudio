{
  "id": "lstm",
  "name": "LSTM 时序预测",
  "version": "2.0.0",
  "min_schema_version": "2.0.0",
  "kind": "algorithm",
  "description": "LSTM model for time series prediction and forecasting",
  "author": "AIStudio",
  "nodes": [
    {
      "type": "model_trainer.lstm",
      "name": "LSTM 时序预测",
      "description": "使用 LSTM 进行时间序列预测",
      "inputs": [
        { "id": "data", "name": "时序数据", "type": "tensor", "required": true }
      ],
      "outputs": [
        { "id": "prediction", "name": "预测结果", "type": "json" }
      ],
      "config_schema": {
        "type": "object",
        "properties": {
          "input_size": { "type": "integer", "default": 10, "minimum": 1, "description": "输入窗口大小" },
          "hidden_size": { "type": "integer", "default": 64, "minimum": 1 },
          "num_layers": { "type": "integer", "default": 2, "minimum": 1, "maximum": 10 },
          "seq_length": { "type": "integer", "default": 24, "minimum": 1 },
          "epochs": { "type": "integer", "default": 50, "minimum": 1 }
        }
      }
    }
  ],
  "runtime_bundle": "pytorch-lstm",
  "supported_targets": ["python"]
}
